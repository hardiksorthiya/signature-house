# Copy to .env.eas (do not commit .env.eas with real secrets)
# Used by: npm run build:ios:testflight

# Expo (https://expo.dev) — create access token: Account Settings → Access Tokens
EXPO_TOKEN=

# After first `eas init`, paste project ID from app.config / expo.dev
EAS_PROJECT_ID=

# Apple Developer (https://developer.apple.com) — paid account required
APPLE_ID=your@email.com
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
# App Store Connect → Apps → your app → App Information → Apple ID (numeric)
APPLE_ASC_APP_ID=

# Laravel .env — public TestFlight invite link (after first TestFlight upload)
# MOBILE_IOS_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX

EXPO_PUBLIC_LARAVEL_URL=https://signature-in-house.com
